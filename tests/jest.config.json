{
    "verbose": true,
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "rootDir": "..",
    "roots": ["<rootDir>/tests", "<rootDir>/src"],
    "collectCoverageFrom": [
        "src/**/*.js"
    ],
    "coverageDirectory": "tests/coverage",
    "coverageReporters": ["text", "lcov", "clover"],
    "coverageThreshold": {
        "global": {
            "branches": 90,
            "functions": 90,
            "lines": 90,
            "statements": 90
        }
    }
}
